---
const { series, labels } = Astro.props;
---

<donut-chart
  data-series={JSON.stringify(series)}
  data-labels={JSON.stringify(labels)}
>

</donut-chart>

<script>
  import { mountDonutChart } from './donut.client';

  class DonutChart extends HTMLElement {
    connectedCallback() {
      const series = JSON.parse(this.dataset.series || '[]');
      const labels = JSON.parse(this.dataset.labels || '[]');
      
      mountDonutChart(this, { series, labels });
    }
  }

  customElements.define('donut-chart', DonutChart);
</script>