---
const { series, labels } = Astro.props;
---

<band-chart
  data-series={JSON.stringify(series)}
  data-labels={JSON.stringify(labels)}
>

</band-chart>

<script>
  import { mountBarChart } from './band.client';

  class BandChart extends HTMLElement {
    connectedCallback() {
      const series = JSON.parse(this.dataset.series || '[]');
      const labels = JSON.parse(this.dataset.labels || '[]');
      
      mountBarChart(this, { series, labels });
    }
  }

  customElements.define('band-chart', BandChart);
</script>