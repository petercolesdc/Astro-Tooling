---
// Formatters
import { slugger } from "../../utls/textFormat";

// Props
const { title, description, hasNav=false, hasTabs=false } = Astro.props;
---
<article id={slugger(title)} class="flex flex-col-reverse gap-6 justify-between items-stretch bg-black/30 backdrop-blur-sm border-2 border-white/20 p-8 rounded-md lg:flex-row">
    <div class="flex flex-col gap-4 justify-between w-full lg:w-1/3">
        <div class="space-y-6">
            <h2 class="text-md text-white heading">{title}</h2>
            <div class="space-y-0.5">
                <h3 class="text-xs text-neutral-500">Company HQ</h3>
                <span class="text-sm text-white">Albuquerque, New Mexico. USA</span>
            </div>
            <div class="space-y-1">
                <h3 class="text-xs text-neutral-500">Distribution of users</h3>
                <ul class="space-y-3">
                    <li class="text-sm text-white"><strong class="text-aqua">Primary:</strong> US East</li>
                    <li class="text-sm text-white">
                        <strong class="text-purple-100">Elsewhere:</strong> Canada, US East, US Central, Mexico, Latin America
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <slot name="graphic">
        <div class="w-full h-96 bg-white/5 flex flex-col items-center justify-center lg:w-2/3">Map here</div>
    </slot>
</article>
