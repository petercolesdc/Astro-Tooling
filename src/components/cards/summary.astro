---
// Formatters
import { slugger } from "../../utls/textFormat";

// Assets
import World from "../../assets/svg/regions/World-by-region.svg";

// Props
const { title, description, hasNav=false, hasTabs=false } = Astro.props;
---

<style is:global>
    #USA-East path {
        color: var(--color-aqua);
    }
    #USA-West path, 
    #USA-Central path,
    #Mexico,
    #Latin-America {
        color: var(--color-purple-100);
    }
</style>
<article id={slugger(title)} class="flex flex-col-reverse gap-8 justify-between items-stretch bg-black/50 backdrop-blur-sm border-2 border-white/20 p-8 rounded-md lg:flex-row">
    <div class="flex flex-col gap-4 justify-between w-full lg:w-1/3">
        <div class="space-y-6">
            <h2 class="text-md text-white heading">{title}</h2>
            <div class="space-y-0.5">
                <h3 class="text-xs text-neutral-500">Company HQ</h3>
                <span class="text-sm text-white">Albuquerque, New Mexico. USA</span>
            </div>
            <div class="space-y-1">
                <h3 class="text-xs text-neutral-500">Distribution of users</h3>
                <ul class="space-y-3">
                    <li class="text-sm text-white"><strong class="text-aqua">Primary:</strong> US East</li>
                    <li class="text-sm text-white">
                        <strong class="text-purple-100">Elsewhere:</strong> US West, US Central, Mexico, Latin America
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <slot name="graphic">
        <World class="w-full text-neutral-800 h-auto max-h-96 flex flex-col items-center justify-center lg:w-2/3" />
    </slot>
</article>
