---
// Formatters
import { safe, uppercase, lowercase, slugger } from "../../utls/textFormat";
// Props
const { label = "Text goes here", type="radio", delayOffset="0" } = Astro.props;
---
<label data-transition="drop-in" style={`--f-delay: ${delayOffset}`} class="flex flex-col size-24 shrink-0 cursor-pointer lg:size-36">
    <input value={slugger(label)} id={`rdch-${slugger(label)}`} type={type} name="options" class="peer sr-only" />
    <div class="p-[2px] flex flex-col w-full h-full items-center justify-center rounded-sm
                bg-linear-120 from-white/20 to-white/20 text-neutral-500 transition-all duration-500
                peer-checked:from-aqua 
                peer-checked:via-purple-100 
                peer-checked:to-blue-100
                peer-checked:text-white
                peer-focus-visible:ring-2 
                peer-focus-visible:ring-white 
                peer-focus-visible:ring-offset-1"
    >
        <span class="flex flex-col h-full w-full items-center justify-center text-center bg-black text-md font-bold p-4">{label}</span>
    </div>
</label>