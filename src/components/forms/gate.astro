---
import Input from './input.astro';
import Select from './select.astro';
import { ArrowRight } from '@lucide/astro';
---

<form id="submit" class="space-y-8">
    <header class="space-y-2">
        <h3 class="text-lg heading">Get the full report for free</h3>
        <p class="text-xs text-secondary leading-normal text-balanced">Access the full report based on the information provided in this assessment.</p>
            <!-- <a href="/tool-4" class="text-link text-link--strong">Edit your answers</a> -->
    </header>
    <fieldset role="group" aria-labelledby="customer-details" class="space-y-6">
        <legend class="sr-only" id="customer-details">Customer details</legend>
        <div class="grid grid-cols-2 gap-3">
            <Input id="given-name" label="Given name"/>
            <Input id="familiy-name" label="Familiy name"/>
        </div>
        <Input id="email" type="email" autocomplete="email" label="Email address"/>
        <Input id="role" label="Job title" required={false}/>
        <Select id="country" label="Country"/>
        <Input id="company" label="Company"/>
        <Select id="hq" label="Company headquarters"/>
    </fieldset>
</div>
    <button class="button button--primary">
        <span class="button__label">Generate report</span>
        <span class="button__icon">
            <ArrowRight size={16} stroke-width={2} />
        </span>
    </button>
</form>