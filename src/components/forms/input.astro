---
// Formatters
import { safe, uppercase, lowercase, slugger } from "../../utls/textFormat";

// Props
const { label = "Given name", type="text", autocomplete="off", id="text-input", value="", error="Error text here", required=true, showError=false } = Astro.props;
---
<div data-component="form/input" class="relative flex flex-col gap-1.5 w-full">
    <label for={`${id}-input`}  
        data-role="form-label"
        class="flex 
        flex-row
        gap-1 
        items-center
        text-xs 
        label 
        text-primary">
        {label}
    {!required &&
        <span class="text-xs leading-none text-secondary">(Optional)</span>
    }
    </label>
    <div class="relative flex flex-col gap-1.5">
        <input id={`${id}-input`} 
            type={type}
            name={id}
            value="" 
            autocomplete={autocomplete} 
            required={required}
            aria-required={required ? "true" : undefined}
            class="relative 
                px-3 
                h-10 
                border-1 
                text-xs 
                border-offset 
                bg-white/5
                text-white 
                leading-tight 
                rounded-xs 
                pe-7 
                truncate 
                cursor-auto 
                transition-colors 
                duration-300 
                ease-in-out 
                placeholder:text-neutral-600 
                caret-violet-100 
                block
                w-full
                max-w-full
                focus:border-violet-100
                focus-visible:outline-0 
                disabled:contrast-more:opacity-90
                disabled:cursor-not-allowed
                disabled:bg-white/30
                disabled:opacity-60"
            >
            {showError &&
                <small data-role="form-meta" class="text-xs flex flex-row items-center gap-2 max-w-3xl text-maroon-100">
                    {error}
                </small>
            }
    </div>
</div>